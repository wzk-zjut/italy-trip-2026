# =====================================================================
# 意大利旅行 2026 —— 环境变量示例
# 复制为 .env.local 后按需修改。Phase 1(本地 JSON)只需前 3 个变量。
# =====================================================================

# ---- Phase 1：本地 JSON（默认，开箱即用）----

# 数据后端：json（默认） | supabase
DATA_BACKEND=json

# 进入 /admin 后台所需的登录口令。请务必改成你自己的口令。
ADMIN_PASSCODE=change-me-please

# 会话 cookie 的签名密钥。请用一段随机长字符串：
#   openssl rand -hex 32
SESSION_SECRET=please-generate-a-long-random-string


# ---- Phase 2：同步到 Supabase 时再填（DATA_BACKEND=supabase 时生效）----

# 项目 URL 与 anon（公开）key —— 用于公开页只读，可安全暴露给前端
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key —— 仅服务端使用，用于后台写入。
# 绝不要加 NEXT_PUBLIC_ 前缀，绝不要提交到仓库！
SUPABASE_SERVICE_ROLE_KEY=
